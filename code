<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Urgent Job Manager</title>
    <style>
        :root {
            --bg: #0f172a;
            --card-bg: #1e293b;
            --text: #f8fafc;
            --pending: #f59e0b;
            --start: #3b82f6;
            --hold: #ef4444;
            --complete: #10b981;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            padding: 20px;
        }

        h1 { text-align: center; font-weight: 300; letter-spacing: 2px; }

        /* Input Section */
        .input-container {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 40px;
        }

        input {
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #334155;
            background: #1e293b;
            color: white;
            width: 250px;
        }

        button {
            padding: 12px 24px;
            border-radius: 8px;
            border: none;
            background: #6366f1;
            color: white;
            cursor: pointer;
            font-weight: bold;
            transition: transform 0.2s;
        }

        button:hover { transform: scale(1.05); background: #818cf8; }

        /* Board Layout */
        .board {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            align-items: start;
        }

        .column {
            background: #1e293b;
            border-radius: 12px;
            padding: 15px;
            min-height: 400px;
            border-top: 5px solid #334155;
        }

        .column[data-status="pending"] { border-color: var(--pending); }
        .column[data-status="start"] { border-color: var(--start); }
        .column[data-status="hold"] { border-color: var(--hold); }
        .column[data-status="complete"] { border-color: var(--complete); }

        .column h2 {
            text-align: center;
            font-size: 1.2rem;
            text-transform: uppercase;
            margin-bottom: 20px;
            color: #94a3b8;
        }

        /* Job Cards */
        .job-card {
            background: #334155;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
            cursor: grab;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
            transition: opacity 0.2s;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .job-card:active { cursor: grabbing; }
        .dragging { opacity: 0.5; }

        .job-id { font-weight: bold; color: #fff; }
        
        /* Dropzone visual cue */
        .column.drag-over {
            background: #2d3748;
            outline: 2px dashed #6366f1;
        }
    </style>
</head>
<body>

    <h1>URGENT JOBS COMMAND</h1>

    <div class="input-container">
        <input type="text" id="jobInput" placeholder="Enter Job ID (e.g. #JOB-101)">
        <button onclick="addJob()">Add Job</button>
    </div>

    <div class="board">
        <div class="column" data-status="pending" ondrop="drop(event)" ondragover="allowDrop(event)" ondragleave="clearStatus(event)">
            <h2>Pending</h2>
            <div id="pending-tasks"></div>
        </div>
        
        <div class="column" data-status="start" ondrop="drop(event)" ondragover="allowDrop(event)" ondragleave="clearStatus(event)">
            <h2>Start</h2>
        </div>

        <div class="column" data-status="hold" ondrop="drop(event)" ondragover="allowDrop(event)" ondragleave="clearStatus(event)">
            <h2>Hold</h2>
        </div>

        <div class="column" data-status="complete" ondrop="drop(event)" ondragover="allowDrop(event)" ondragleave="clearStatus(event)">
            <h2>Complete</h2>
        </div>
    </div>

    <script>
        function addJob() {
            const input = document.getElementById('jobInput');
            const jobId = input.value.trim();
            
            if (jobId === "") {
                alert("Please enter a valid Job ID");
                return;
            }

            const card = document.createElement('div');
            card.className = 'job-card';
            card.draggable = true;
            card.id = 'job-' + Date.now(); // Unique ID for the element
            card.innerHTML = `<span class="job-id">${jobId}</span>`;
            
            // Drag Start Event
            card.addEventListener('dragstart', (e) => {
                e.dataTransfer.setData("text", e.target.id);
                card.classList.add('dragging');
            });

            card.addEventListener('dragend', () => {
                card.classList.remove('dragging');
            });

            document.getElementById('pending-tasks').appendChild(card);
            input.value = ""; // Clear input
        }

        // Drag and Drop Logic
        function allowDrop(e) {
            e.preventDefault();
            e.currentTarget.classList.add('drag-over');
        }

        function clearStatus(e) {
            e.currentTarget.classList.remove('drag-over');
        }

        function drop(e) {
            e.preventDefault();
            const column = e.currentTarget;
            column.classList.remove('drag-over');
            
            const data = e.dataTransfer.getData("text");
            const draggedElement = document.getElementById(data);
            
            // Append the card to the new column
            column.appendChild(draggedElement);
        }
    </script>
</body>
</html>
